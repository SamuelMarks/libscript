{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/app/_storage/celery/vars.schema.json",
  "title": "celery storage vars",
  "description": "celery storage vars that can be set",
  "type": "object",
  "properties": {
    "JUPYTERHUB_SERVICE_USER": {
      "description": "User (try-create); use for the daemon",
      "type": "string"
    },
    "PYTHON_VENV": {
      "description": "Python virtualenv to install & then start the celery daemon from",
      "type": "string"
    },
    "LIBSCRIPT_GLOBAL_INSTALL_METHOD": {
      "description": "Global override for how software should be installed across all systems (e.g. system package manager vs downloaded binaries/from-source).",
      "type": "string",
      "enum": [
        "system",
        "source"
      ],
      "default": "system"
    },
    "LIBSCRIPT_WINDOWS_PKG_MGR": {
      "description": "Global package manager override for Windows targets (e.g. winget, choco).",
      "type": "string",
      "enum": [
        "winget",
        "choco"
      ],
      "default": "winget"
    },
    "CELERY_SERVICE_USER": {
      "type": "string",
      "description": "Variable CELERY_SERVICE_USER."
    },
    "PREFIX": {
      "type": "string",
      "description": "Installation prefix."
    },
    "LIBSCRIPT_LOG_DRIVER": {
      "type": "string",
      "description": "Logging driver to use (e.g., fluentd)."
    },
    "LIBSCRIPT_LOG_HOST": {
      "type": "string",
      "description": "Host for remote logging."
    },
    "GROUP": {
      "type": "string",
      "description": "Variable GROUP."
    },
    "LIBSCRIPT_LOG_PORT": {
      "type": "string",
      "description": "Port for remote logging."
    },
    "PYTHON_VERSION": {
      "type": "string",
      "description": "Variable PYTHON_VERSION."
    },
    "FORMAT": {
      "type": "string",
      "description": "Output format (e.g., json, text)."
    },
    "LOGS_DIR": {
      "type": "string",
      "description": "Directory where logs should be stored."
    },
    "SERVE_FROM": {
      "type": "string",
      "description": "Base directory or context path from which the service should be served."
    },
    "LIBSCRIPT_VERSION": {
      "type": "string",
      "description": "Specifies the version of the package to use."
    },
    "VAULT_TOKEN": {
      "type": "string",
      "description": "Token for HashiCorp Vault authentication."
    },
    "LIBSCRIPT_SERVICE_NAME": {
      "type": "string",
      "description": "Overrides the default service name."
    }
  }
}