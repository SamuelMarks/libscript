{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema for install JSON file",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "scripts_root": {
      "type": "string"
    },
    "wwwroot": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "https": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string"
              }
            },
            "required": [
              "provider"
            ]
          },
          "builder": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "shell": {
                  "type": "string"
                },
                "commands": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "output": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "commands"
              ]
            }
          },
          "env": {
            "type": "string"
          },
          "listen": {
            "type": "string"
          },
          "dependencies": {
            "$ref": "#/definitions/Dependencies"
          },
          "domain": {
            "type": "string"
          },
          "subdomain": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "env"
        ]
      }
    },
    "dependencies": {
      "$ref": "#/definitions/Dependencies"
    },
    "log_server": {
      "type": "object",
      "properties": {
        "optional": {
          "type": "boolean"
        }
      },
      "required": []
    },
    "provides": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Virtual capabilities this installer provides (e.g., ['database', 'mysql-compatible'])"
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Capabilities or components this conflicts with (e.g., ['mysql-compatible'])"
    },
    "os_whitelist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of supported operating systems (e.g., ['linux', 'darwin', 'windows', 'all']). Default is ['all']."
    },
    "os_blacklist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of explicitly unsupported operating systems (e.g., ['windows'])."
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of explicit semantic versions this component can install (e.g., ['8.0.28', '8.1.17', '8.2.4']). If omitted, assumes it can satisfy any version request or 'latest'."
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "List of default TCP/UDP ports this component binds to (e.g., [80, 443]). Used by the SAT solver for conflict detection."
    }
  },
  "required": [
    "name",
    "scripts_root",
    "dependencies"
  ],
  "definitions": {
    "Dependencies": {
      "type": "object",
      "properties": {
        "required": {
          "type": "object",
          "properties": {
            "databases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "listen": {
                    "type": "string"
                  },
                  "env": {
                    "type": "string"
                  },
                  "target_env": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "vars": {
                    "type": "object"
                  },
                  "anyOf": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of capabilities where at least one must be provided."
                  }
                },
                "required": [
                  "version",
                  "env"
                ],
                "oneOf": [
                  {
                    "required": [
                      "name"
                    ]
                  },
                  {
                    "required": [
                      "anyOf"
                    ]
                  }
                ]
              }
            },
            "toolchains": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "listen": {
                    "type": "string"
                  },
                  "env": {
                    "type": "string"
                  },
                  "anyOf": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of capabilities where at least one must be provided."
                  }
                },
                "required": [
                  "version",
                  "env"
                ],
                "oneOf": [
                  {
                    "required": [
                      "name"
                    ]
                  },
                  {
                    "required": [
                      "anyOf"
                    ]
                  }
                ]
              }
            },
            "servers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dest": {
                    "type": "string"
                  },
                  "listen": {
                    "type": "string"
                  },
                  "builder": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "shell": {
                          "type": "string"
                        },
                        "commands": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "output": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      },
                      "required": [
                        "commands"
                      ]
                    }
                  },
                  "daemon": {
                    "type": "object",
                    "properties": {
                      "os_native": {
                        "type": "boolean"
                      },
                      "listen": {
                        "type": "string"
                      },
                      "env": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "os_native"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "anyOf": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of capabilities where at least one must be provided."
                  }
                },
                "required": [
                  "daemon"
                ],
                "oneOf": [
                  {
                    "required": [
                      "name"
                    ]
                  },
                  {
                    "required": [
                      "anyOf"
                    ]
                  }
                ]
              }
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Virtual capabilities required by this installer (e.g., ['web-server'])"
            }
          },
          "required": []
        },
        "optional": {
          "type": "object",
          "properties": {
            "databases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "listen": {
                    "type": "string"
                  },
                  "env": {
                    "type": "string"
                  },
                  "vars": {
                    "type": "object"
                  },
                  "anyOf": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of capabilities where at least one must be provided."
                  }
                },
                "required": [
                  "version",
                  "env"
                ],
                "oneOf": [
                  {
                    "required": [
                      "name"
                    ]
                  },
                  {
                    "required": [
                      "anyOf"
                    ]
                  }
                ]
              }
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Virtual capabilities required by this installer (e.g., ['web-server'])"
            }
          },
          "required": []
        }
      },
      "required": []
    }
  }
}