{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/_common/base_vars.schema.json",
  "title": "LibScript Base Component Variables",
  "description": "Common variables shared by all LibScript components",
  "type": "object",
  "properties": {
    "LIBSCRIPT_GLOBAL_INSTALL_METHOD": {
      "description": "Global override for how software should be installed (system vs source).",
      "type": "string",
      "enum": [
        "system",
        "source"
      ],
      "default": "system"
    },
    "LIBSCRIPT_WINDOWS_PKG_MGR": {
      "description": "Global package manager override for Windows (winget, choco).",
      "type": "string",
      "enum": [
        "winget",
        "choco"
      ],
      "default": "winget"
    },
    "LIBSCRIPT_LOG_LEVEL": {
      "type": "string",
      "description": "Minimum logging level (0=DEBUG, 1=INFO, 2=SUCCESS, 3=WARN, 4=ERROR).",
      "default": "1"
    },
    "LIBSCRIPT_LOG_FORMAT": {
      "type": "string",
      "description": "Output format for logs (text, json).",
      "enum": ["text", "json"],
      "default": "text"
    },
    "LIBSCRIPT_LOG_FILE": {
      "type": "string",
      "description": "File to write logs to (in addition to standard output)."
    },
    "LIBSCRIPT_SERVICE_NAME": {
      "type": "string",
      "description": "Overrides the default service name."
    },
    "DOWNLOAD_DIR": {
      "type": "string",
      "description": "Directory where downloads are stored."
    },
    "FORMAT": {
      "type": "string",
      "description": "Output format (e.g., json, text)."
    },
    "LIBSCRIPT_CACHE_DIR": {
      "type": "string",
      "description": "Directory where cached files are stored."
    },
    "LIBSCRIPT_LOG_DRIVER": {
      "type": "string",
      "description": "Logging driver to use (e.g., fluentd)."
    },
    "LOGS_DIR": {
      "type": "string",
      "description": "Directory where logs should be stored."
    },
    "VAULT_TOKEN": {
      "type": "string",
      "description": "Token for HashiCorp Vault authentication."
    },
    "PREFIX": {
      "type": "string",
      "description": "Installation prefix."
    },
    "SERVE_FROM": {
      "type": "string",
      "description": "Base directory or context path for the service."
    },
    "LIBSCRIPT_LOG_HOST": {
      "type": "string",
      "description": "Host for remote logging."
    },
    "LIBSCRIPT_VERSION": {
      "type": "string",
      "description": "Specifies the version of the package to use."
    },
    "LIBSCRIPT_LOG_PORT": {
      "type": "string",
      "description": "Port for remote logging."
    }
  }
}
