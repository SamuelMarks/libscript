{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/toolchains/gradle/vars.schema.json",
  "title": "Gradle variables",
  "description": "Configuration variables for Gradle",
  "type": "object",
  "properties": {
    "GRADLE_VERSION": {
      "description": "Specific version of gradle to install. Can be a numeric version or an alias.",
      "type": "string",
      "default": "latest"
    }
  }
}
