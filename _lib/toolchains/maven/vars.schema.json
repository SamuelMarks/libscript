{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/toolchains/maven/vars.schema.json",
  "title": "Maven variables",
  "description": "Configuration variables for Maven",
  "type": "object",
  "properties": {
    "MAVEN_VERSION": {
      "description": "Specific version of maven to install. Can be a numeric version or an alias.",
      "type": "string",
      "default": "latest"
    }
  }
}
