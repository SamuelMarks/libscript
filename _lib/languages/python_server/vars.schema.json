{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/languages/python_server/vars.schema.json",
  "title": "python_server vars",
  "description": "Variables for Python App Server",
  "type": "object",
  "properties": {
    "DEST": {
      "description": "Destination (working directory)",
      "type": "string"
    },
    "VARS": {
      "description": "Key/value in JSON format (as an escaped string)",
      "type": "string"
    },
    "VENV": {
      "description": "Path to a Python virtualenv",
      "type": "string"
    },
    "LIBSCRIPT_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Global port to listen on"
    },
    "LIBSCRIPT_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Global address to listen on"
    },
    "LIBSCRIPT_LISTEN_SOCKET": {
      "type": "string",
      "description": "Global unix socket to listen on"
    },
    "PYTHON_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Port for PYTHON to listen on"
    },
    "PYTHON_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Address for PYTHON to listen on"
    },
    "PYTHON_LISTEN_SOCKET": {
      "type": "string",
      "description": "Unix socket for PYTHON to listen on"
    }
  }
}
