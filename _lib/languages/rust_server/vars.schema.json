{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/languages/rust_server/vars.schema.json",
  "title": "rust_server vars",
  "description": "Variables for Rust App Server",
  "type": "object",
  "properties": {
    "DEST": {
      "description": "Destination (working directory)",
      "type": "string"
    },
    "VARS": {
      "description": "Key/value in JSON format (as an escaped string)",
      "type": "string"
    },
    "LIBSCRIPT_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Global port to listen on"
    },
    "LIBSCRIPT_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Global address to listen on"
    },
    "LIBSCRIPT_LISTEN_SOCKET": {
      "type": "string",
      "description": "Global unix socket to listen on"
    },
    "RUST_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Port for RUST to listen on"
    },
    "RUST_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Address for RUST to listen on"
    },
    "RUST_LISTEN_SOCKET": {
      "type": "string",
      "description": "Unix socket for RUST to listen on"
    }
  }
}
