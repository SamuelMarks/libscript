{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/languages/nodejs_server/vars.schema.json",
  "title": "nodejs_server vars",
  "description": "Variables for Node.js App Server",
  "type": "object",
  "properties": {
    "DEST": {
      "description": "Destination (working directory)",
      "type": "string"
    },
    "VARS": {
      "description": "Key/value in JSON format (as an escaped string)",
      "type": "string"
    },
    "LIBSCRIPT_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Global port to listen on"
    },
    "LIBSCRIPT_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Global address to listen on"
    },
    "LIBSCRIPT_LISTEN_SOCKET": {
      "type": "string",
      "description": "Global unix socket to listen on"
    },
    "NODEJS_LISTEN_PORT": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Port for NODEJS to listen on"
    },
    "NODEJS_LISTEN_ADDRESS": {
      "type": "string",
      "description": "Address for NODEJS to listen on"
    },
    "NODEJS_LISTEN_SOCKET": {
      "type": "string",
      "description": "Unix socket for NODEJS to listen on"
    }
  }
}
