{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/languages/nodejs/vars.schema.json",
  "title": "nodejs vars",
  "description": "Variables for Node.js Runtime",
  "type": "object",
  "properties": {
    "NODEJS_VERSION": {
      "description": "Version of Node.js demanded. Can be an alias or a specific numeric version number",
      "type": "string",
      "default": "lts",
      "versionAliases": [
        "lts",
        "latest"
      ],
      "examples": [
        "lts",
        "latest",
        "v22.13.1",
        "20"
      ]
    },
    "NODEJS_INSTALL_METHOD": {
      "description": "How to install NODEJS. 'system' uses the native OS package manager, 'source' compiles/downloads binaries.",
      "type": "string",
      "enum": [
        "system",
        "source"
      ],
      "default": "system"
    }
  }
}
