{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/package-managers/krew/vars.schema.json",
  "title": "Krew variables",
  "description": "Configuration variables for krew",
  "type": "object",
  "properties": {
    "KREW_ROOT": {
      "type": "string",
      "description": "Installation directory for krew and plugins. Defaults to ~/.krew."
    },
    "KREW_VERSION": {
      "description": "Specific version of krew to install.",
      "type": "string",
      "default": "latest"
    }
  }
}
