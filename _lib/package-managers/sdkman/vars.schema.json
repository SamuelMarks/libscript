{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/package-managers/sdkman/vars.schema.json",
  "title": "Sdkman variables",
  "description": "Configuration variables for sdkman",
  "type": "object",
  "properties": {
    "SDKMAN_DIR": {
      "type": "string",
      "description": "Installation directory for SDKMAN!. Defaults to ~/.sdkman."
    },
    "SDKMAN_VERSION": {
      "description": "Specific version of sdkman to install.",
      "type": "string",
      "default": "latest"
    }
  }
}
