{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/package-managers/fnm/vars.schema.json",
  "title": "Fnm variables",
  "description": "Configuration variables for fnm",
  "type": "object",
  "properties": {
    "FNM_DIR": {
      "type": "string",
      "description": "Installation directory for fnm."
    },
    "FNM_VERSION": {
      "description": "Specific version of fnm to install.",
      "type": "string",
      "default": "latest"
    }
  }
}
