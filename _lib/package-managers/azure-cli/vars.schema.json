{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Azure Cli variables",
  "description": "Configuration variables for azure-cli",
  "type": "object",
  "properties": {
    "AZURECLI_VERSION": {
      "type": "string",
      "default": "latest",
      "description": "Version of Azure CLI to install"
    },
    "AZURE_CLI_VERSION": {
      "description": "Specific version of azure-cli to install.",
      "type": "string",
      "default": "latest"
    }
  }
}
