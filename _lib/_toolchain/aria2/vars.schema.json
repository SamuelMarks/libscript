{
  "properties": {
    "ARIA2_VERSION": {
      "type": "string",
      "default": "latest",
      "description": "Version of aria2 to install."
    },
    "ARIA2_INSTALL_METHOD": {
      "type": "string",
      "default": "system",
      "description": "Install method for aria2 ('system' or 'source')"
    },
    "DOWNLOAD_DIR": {
      "type": "string",
      "description": "Directory where downloads are stored."
    },
    "LIBSCRIPT_CACHE_DIR": {
      "type": "string",
      "description": "Directory where cached files are stored."
    },
    "LIBSCRIPT_GLOBAL_INSTALL_METHOD": {
      "type": "string",
      "description": "Global override for how software should be installed."
    }
  }
}