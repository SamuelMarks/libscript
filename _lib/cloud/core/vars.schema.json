{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/cloud/core/vars.schema.json",
  "title": "Cloud Wrapper",
  "description": "Unified multicloud wrapper for AWS, Azure, and GCP",
  "type": "object",
  "properties": {
    "LIBSCRIPT_DEFAULT_CLOUD": {
      "type": "string",
      "enum": [
        "aws",
        "azure",
        "gcp"
      ],
      "default": "aws",
      "description": "Default cloud provider to use"
    },
    "CORE_AWS_ACCESS_KEY_ID": {
      "type": "string",
      "description": "AWS Access Key ID"
    },
    "CORE_AWS_SECRET_ACCESS_KEY": {
      "type": "string",
      "description": "AWS Secret Access Key"
    },
    "CORE_AZURE_SUBSCRIPTION_ID": {
      "type": "string",
      "description": "Azure Subscription ID"
    },
    "CORE_GCP_PROJECT_ID": {
      "type": "string",
      "description": "GCP Project ID"
    }
  }
}
