{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/_lib/init-systems/systemd/vars.schema.json",
  "title": "systemd daemon vars",
  "description": "Variables to configure systemd services",
  "type": "object",
  "properties": {
    "EXEC_START": {
      "description": "Executor",
      "type": "string"
    },
    "WORKING_DIR": {
      "description": "Working directory that `EXEC_START` will be run from",
      "type": "string"
    },
    "ENV": {
      "description": "Optional additional properties as key/value pairs",
      "type": "string"
    },
    "PREFIX": {
      "type": "string",
      "description": "Installation prefix."
    },
    "SERVE_FROM": {
      "type": "string",
      "description": "Base directory or context path from which the service should be served."
    },
    "FORMAT": {
      "type": "string",
      "description": "Output format (e.g., json, text)."
    },
    "LIBSCRIPT_SERVICE_NAME": {
      "type": "string",
      "description": "Overrides the default service name."
    },
    "LIBSCRIPT_LOG_HOST": {
      "type": "string",
      "description": "Host for remote logging."
    },
    "LIBSCRIPT_LOG_DRIVER": {
      "type": "string",
      "description": "Logging driver to use (e.g., fluentd)."
    },
    "LOGS_DIR": {
      "type": "string",
      "description": "Directory where logs should be stored."
    },
    "VAULT_TOKEN": {
      "type": "string",
      "description": "Token for HashiCorp Vault authentication."
    },
    "LIBSCRIPT_VERSION": {
      "type": "string",
      "description": "Specifies the version of the package to use."
    },
    "LIBSCRIPT_LOG_PORT": {
      "type": "string",
      "description": "Port for remote logging."
    }
  }
}